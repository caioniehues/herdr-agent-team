      import os, time, json
      run = '/home/caio/.local/state/herdr/plugins/caioniehues.agent-team/runs/stage0-run1-1784132209-1784132209809'
      start = time.time()
      seen = {}
      def snapshot():
          out = {}
          for root, dirs, files in os.walk(run):
              for f in files:
                  p = os.path.join(root, f)
                  try:
                      out[p] = os.path.getmtime(p)
                  except OSError:
                      pass
          return out
      seen = snapshot()
      print("initial files:")
      for p in sorted(seen): print("  ", p)
      while time.time() - start < 32:
          time.sleep(1)
          now = snapshot()
          for p, m in now.items():
              if p not in seen or m != seen[p]:
                  print(f"[{time.time()-start:5.1f}s] changed: {p}")
                  try:
                      with open(p) as fh:
